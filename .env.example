# Database Credentials (được truyền vào mongodb)
MONGO_INITDB_ROOT_USERNAME=your_mongo_admin_username
MONGO_INITDB_ROOT_PASSWORD=your_secure_mongo_password

# API Configuration (được truyền vào API)
PORT=3000
MONGODB_URI=mongodb://your_mongo_admin_username:your_secure_mongo_password@mongodb:27017/kpi_management?authSource=admin
JWT_SECRET=your_random_jwt_secret
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10
